generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  email        String     @unique
  password     String
  role         UserRole   @default(client)
  status       UserStatus @default(pending)
  profileImage String?    @map("profile_image")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  profile      Profile?

  @@map("users")
}

model Profile {
  id               String           @id @default(uuid())
  userId           String           @unique @map("user_id")
  bio              String?
  phone            String?
  city             String?
  state            String?
  location         String?
  timeZone         String?          @map("time_zone")
  preferredContact String?          @map("preferred_contact")
  totalEarnings    Decimal          @default(0.0) @map("total_earnings") @db.Decimal(10, 2)
  jobsCompleted    Int              @default(0) @map("jobs_completed")
  visibility       VisibilityStatus @default(public)
  ratePerHour      Decimal?         @map("rate_per_hour") @db.Decimal(10, 2)
  services         String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  icon        String?
  iconType    IconType       @default(emoji)
  color       String?
  status      CategoryStatus @default(active)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("categories")
}

enum UserRole {
  admin
  client
  errand
}

enum UserStatus {
  active
  deactivated
  pending
}

enum VisibilityStatus {
  public
  private
}

enum IconType {
  emoji
  url
}

enum CategoryStatus {
  active
  inactive
}
