generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(uuid())
  firstName            String          @map("first_name")
  lastName             String          @map("last_name")
  email                String          @unique
  password             String
  role                 UserRole        @default(client)
  status               UserStatus      @default(pending)
  profileImage         String?         @map("profile_image")
  resetPasswordToken   String?         @map("reset_password_token")
  resetPasswordExpires DateTime?       @map("reset_password_expires")
  deleteAccountToken   String?         @map("delete_account_token")
  deleteAccountExpires DateTime?       @map("delete_account_expires")
  twoFactorSecret      String?         @map("two_factor_secret")
  isTwoFactorEnabled   Boolean         @default(false) @map("is_two_factor_enabled")
  recoveryCodes        String[]        @map("recovery_codes")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  profile              Profile?
  loginActivities      LoginActivity[]
  securityLogs         SecurityLog[]
  posts                Post[]          @relation("UserPosts")
  assignedPosts        Post[]          @relation("AssignedPosts")
  subscription         Subscription?
  paymentHistories     PaymentHistory[]

  @@map("users")
}

model Profile {
  id               String           @id @default(uuid())
  userId           String           @unique @map("user_id")
  bio              String?
  phone            String?
  city             String?
  state            String?
  location         String?
  timeZone         String?          @map("time_zone")
  preferredContact String?          @map("preferred_contact")
  totalEarnings    Decimal          @default(0.0) @map("total_earnings") @db.Decimal(10, 2)
  jobsCompleted    Int              @default(0) @map("jobs_completed")
  visibility       VisibilityStatus @default(public)
  ratePerHour      Decimal?         @map("rate_per_hour") @db.Decimal(10, 2)
  services         String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model LoginActivity {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  device     String
  browser    String
  os         String?
  ipAddress  String?  @map("ip_address")
  location   String?
  deviceIcon String   @default("globe") @map("device_icon")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_activities")
}

model SecurityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  event      String   // e.g., 'PASSWORD_CHANGE', '2FA_ENABLED', '2FA_DISABLED'
  device     String?
  browser    String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_logs")
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  icon        String?
  iconType    IconType       @default(emoji)
  color       String?
  status      CategoryStatus @default(active)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  posts       Post[]

  @@map("categories")
}

model Post {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  description String
  city        String
  state       String
  budget      Decimal? @db.Decimal(10, 2)
  dateNeeded  DateTime? @map("date_needed")
  time        String?
  serviceType String?  @map("service_type")
  contactInfo String?  @map("contact_info")
  photoUrl    String?  @map("photo_url")
  youtubeLink String?  @map("youtube_link")
  categoryId  String   @map("category_id")
  status      String   @default("active")
  assignedToId String? @map("assigned_to_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user       User     @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation("AssignedPosts", fields: [assignedToId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@map("posts")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  status               SubscriptionStatus @default(incomplete)
  planName             String             @default("ErrandHub Monthly Subscription") @map("plan_name")
  amount               Decimal            @db.Decimal(10, 2)
  currency             String             @default("usd")
  interval             String             @default("month")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")
  latestInvoiceId      String?            @map("latest_invoice_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentHistories PaymentHistory[]

  @@map("subscriptions")
}

model PaymentHistory {
  id                    String         @id @default(uuid())
  userId                String         @map("user_id")
  subscriptionId        String?        @map("subscription_id")
  stripeInvoiceId       String?        @unique @map("stripe_invoice_id")
  stripePaymentIntentId String?        @map("stripe_payment_intent_id")
  stripeChargeId        String?        @map("stripe_charge_id")
  amountPaid            Decimal        @db.Decimal(10, 2) @map("amount_paid")
  amountDue             Decimal        @db.Decimal(10, 2) @map("amount_due")
  currency              String         @default("usd")
  status                PaymentStatus  @default(pending)
  invoiceUrl            String?        @map("invoice_url")
  invoicePdf            String?        @map("invoice_pdf")
  hostedInvoiceUrl      String?        @map("hosted_invoice_url")
  paidAt                DateTime?      @map("paid_at")
  billingReason         String?        @map("billing_reason")
  failureReason         String?        @map("failure_reason")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@map("payment_histories")
}

model WebhookEvent {
  id              String   @id @default(uuid())
  stripeEventId   String   @unique @map("stripe_event_id")
  type            String
  processed       Boolean  @default(false)
  processingError String?  @map("processing_error")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("webhook_events")
}

enum SubscriptionStatus {
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  paused
  trialing
  unpaid
}

enum PaymentStatus {
  succeeded
  pending
  failed
}

enum UserRole {
  admin
  client
  errand
}

enum UserStatus {
  active
  deactivated
  pending
}

enum VisibilityStatus {
  public
  private
}

enum IconType {
  emoji
  url
}

enum CategoryStatus {
  active
  inactive
}
