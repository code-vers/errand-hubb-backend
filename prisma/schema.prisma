generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String           @id @default(uuid())
  firstName             String           @map("first_name")
  lastName              String           @map("last_name")
  email                 String           @unique
  password              String
  role                  UserRole         @default(client)
  status                UserStatus       @default(pending)
  profileImage          String?          @map("profile_image")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  resetPasswordExpires  DateTime?        @map("reset_password_expires")
  resetPasswordToken    String?          @map("reset_password_token")
  isTwoFactorEnabled    Boolean          @default(false) @map("is_two_factor_enabled")
  twoFactorSecret       String?          @map("two_factor_secret")
  deleteAccountExpires  DateTime?        @map("delete_account_expires")
  deleteAccountToken    String?          @map("delete_account_token")
  recoveryCodes         String[]         @map("recovery_codes")
  
  // Email Verification
  isVerified            Boolean          @default(false) @map("is_verified")
  verificationToken     String?          @map("verification_token")
  verificationTokenExpires DateTime?     @map("verification_token_expires")
  conversationsAsClient Conversation[]   @relation("ClientConversations")
  conversationsAsErrand Conversation[]   @relation("ErrandConversations")
  loginActivities       LoginActivity[]
  sentMessages          Message[]        @relation("SentMessages")
  notifications         Notification[]
  paymentHistories      PaymentHistory[]
  assignedPosts         Post[]           @relation("AssignedPosts")
  posts                 Post[]           @relation("UserPosts")
  profile               Profile?
  securityLogs          SecurityLog[]
  subscription          Subscription?
  serviceRequests       ServiceRequest[] @relation("UserServiceRequests")

  // Ads Relations
  ads                   Ad[]             @relation("UserAds")
  adsSubscription       AdsSubscription?

  @@map("users")
}

model Conversation {
  id               String          @id @default(uuid())
  clientId         String          @map("client_id")
  errandId         String          @map("errand_id")
  serviceRequestId String?         @map("service_request_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  client           User            @relation("ClientConversations", fields: [clientId], references: [id])
  errand           User            @relation("ErrandConversations", fields: [errandId], references: [id])
  serviceRequest   ServiceRequest? @relation("ServiceRequestConversations", fields: [serviceRequestId], references: [id], onDelete: SetNull)
  messages         Message[]

  @@unique([clientId, errandId, serviceRequestId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  content        String
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")
  metadata       Json?
  type           String       @default("text")
  deletedFor     String[]     @default([]) @map("deleted_for")
  isDeleted      Boolean      @default(false) @map("is_deleted")
  isPinned       Boolean      @default(false) @map("is_pinned")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  metadata  Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Profile {
  id               String           @id @default(uuid())
  userId           String           @unique @map("user_id")
  bio              String?
  phone            String?
  city             String?
  state            String?
  location         String?
  timeZone         String?          @map("time_zone")
  preferredContact String?          @map("preferred_contact")
  totalEarnings    Decimal          @default(0.0) @map("total_earnings") @db.Decimal(10, 2)
  jobsCompleted    Int              @default(0) @map("jobs_completed")
  visibility       VisibilityStatus @default(public)
  ratePerHour      Decimal?         @map("rate_per_hour") @db.Decimal(10, 2)
  services         String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  youtubeLink      String?          @map("youtube_link")
  gallery          String[]         @default([])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model LoginActivity {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  device     String
  browser    String
  os         String?
  ipAddress  String?  @map("ip_address")
  location   String?
  deviceIcon String   @default("globe") @map("device_icon")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_activities")
}

model SecurityLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  event     String
  device    String?
  browser   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_logs")
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  icon        String?
  iconType    IconType       @default(emoji)
  color       String?
  status      CategoryStatus @default(active)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  posts           Post[]
  serviceRequests ServiceRequest[]

  @@map("categories")
}

model Post {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  title        String
  description  String
  city         String
  state        String
  budget       Decimal?  @db.Decimal(10, 2)
  dateNeeded   DateTime? @map("date_needed")
  contactInfo  String?   @map("contact_info")
  photoUrl     String?   @map("photo_url")
  categoryId   String    @map("category_id")
  status       String    @default("active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  youtubeLink  String?   @map("youtube_link")
  assignedToId String?   @map("assigned_to_id")
  serviceType  String?   @map("service_type")
  time         String?
  assignedTo   User?     @relation("AssignedPosts", fields: [assignedToId], references: [id])
  category     Category  @relation(fields: [categoryId], references: [id])
  user         User      @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  status               SubscriptionStatus @default(incomplete)
  planName             String             @default("ErrandHub Monthly Subscription") @map("plan_name")
  amount               Decimal            @db.Decimal(10, 2)
  currency             String             @default("usd")
  interval             String             @default("month")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")
  latestInvoiceId      String?            @map("latest_invoice_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  paymentHistories     PaymentHistory[]
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PaymentHistory {
  id                    String           @id @default(uuid())
  userId                String           @map("user_id")
  subscriptionId        String?          @map("subscription_id")
  adsSubscriptionId     String?          @map("ads_subscription_id")
  stripeInvoiceId       String?          @unique @map("stripe_invoice_id")
  stripePaymentIntentId String?          @map("stripe_payment_intent_id")
  stripeChargeId        String?          @map("stripe_charge_id")
  amountPaid            Decimal          @map("amount_paid") @db.Decimal(10, 2)
  amountDue             Decimal          @map("amount_due") @db.Decimal(10, 2)
  currency              String           @default("usd")
  status                PaymentStatus    @default(pending)
  invoiceUrl            String?          @map("invoice_url")
  invoicePdf            String?          @map("invoice_pdf")
  hostedInvoiceUrl      String?          @map("hosted_invoice_url")
  paidAt                DateTime?        @map("paid_at")
  billingReason         String?          @map("billing_reason")
  failureReason         String?          @map("failure_reason")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  subscription          Subscription?    @relation(fields: [subscriptionId], references: [id])
  adsSubscription       AdsSubscription? @relation(fields: [adsSubscriptionId], references: [id])
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_histories")
}

model WebhookEvent {
  id              String   @id @default(uuid())
  stripeEventId   String   @unique @map("stripe_event_id")
  type            String
  processed       Boolean  @default(false)
  processingError String?  @map("processing_error")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("webhook_events")
}

enum SubscriptionStatus {
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  paused
  trialing
  unpaid
}

enum PaymentStatus {
  succeeded
  pending
  failed
}

enum UserRole {
  admin
  client
  errand
}

enum UserStatus {
  active
  deactivated
  pending
}

enum VisibilityStatus {
  public
  private
}

enum IconType {
  emoji
  url
}

enum ServiceRequestStatus {
  draft
  active
  in_discussion
  assigned
  completed
  cancelled
  expired
}

enum CategoryStatus {
  active
  inactive
}

model AdCategory {
  id            String          @id @default(uuid())
  name          String          @unique
  slug          String          @unique
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  subcategories AdSubcategory[]
  ads           Ad[]

  @@map("ad_categories")
}

model AdSubcategory {
  id         String     @id @default(uuid())
  categoryId String     @map("category_id")
  name       String
  slug       String
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  category   AdCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  ads        Ad[]

  @@unique([categoryId, name])
  @@unique([categoryId, slug])
  @@map("ad_subcategories")
}

model Ad {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  title         String
  companyName   String        @map("company_name")
  description   String        @db.Text
  categoryId    String        @map("category_id")
  subcategoryId String?       @map("subcategory_id")
  imageUrl      String?       @map("image_url")
  location      String?       @map("location")
  contactInfo   String?       @map("contact_info")
  youtubeLink   String?       @map("youtube_link")
  status        AdStatus      @default(active)
  isFeatured    Boolean       @default(false) @map("is_featured")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user        User           @relation("UserAds", fields: [userId], references: [id], onDelete: Cascade)
  category    AdCategory     @relation(fields: [categoryId], references: [id])
  subcategory AdSubcategory? @relation(fields: [subcategoryId], references: [id])

  @@map("ads")
}

model AdsSubscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  status               SubscriptionStatus @default(incomplete)
  planName             String             @default("ErrandHub Ads Monthly Subscription") @map("plan_name")
  amount               Decimal            @db.Decimal(10, 2)
  currency             String             @default("usd")
  interval             String             @default("month")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentHistories PaymentHistory[]

  @@map("ads_subscriptions")
}

enum AdStatus {
  draft
  active
  inactive
  pending
  approved
  rejected
}

model ServiceRequest {
  id            String               @id @default(uuid())
  userId        String               @map("user_id")
  title         String
  description   String               @db.Text
  categoryId    String               @map("category_id")
  budget        Decimal?             @db.Decimal(10, 2)
  city          String
  state         String?
  dateNeeded    DateTime?            @map("date_needed")
  time          String?
  urgencyLevel  String               @default("normal") @map("urgency_level")
  imageUrl      String?              @map("image_url")
  status        ServiceRequestStatus @default(active)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  user          User                 @relation("UserServiceRequests", fields: [userId], references: [id], onDelete: Cascade)
  category      Category             @relation(fields: [categoryId], references: [id])
  conversations Conversation[]       @relation("ServiceRequestConversations")

  @@map("service_requests")
}

enum MerchandiseOrderStatus {
  pending
  accepted
  shipped
  delivered
  cancelled
}

model MerchandiseOrder {
  id          String                 @id @default(uuid())
  name        String
  email       String
  address     String
  city        String
  state       String
  zipCode     String                 @map("zip_code")
  items       Json
  totalAmount Decimal                @map("total_amount") @db.Decimal(10, 2)
  status      MerchandiseOrderStatus @default(pending)
  isPaid      Boolean                @default(false) @map("is_paid")
  stripeSessionId String?            @map("stripe_session_id")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  @@map("merchandise_orders")
}
